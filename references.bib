% ============================================================
%  参考文献数据库
%  条目格式依期刊要求调整（这里是 BibTeX 标准格式示例）
% ============================================================

% --- 期刊论文示例 ---
@article{example2024,
  author  = {Author, First and Author, Second},
  title   = {An Example Article Title},
  journal = {Journal of Examples},
  volume  = {1},
  number  = {1},
  pages   = {1--10},
  year    = {2024},
  doi     = {10.xxxx/example},
}

% --- 会议论文示例 ---
@inproceedings{confexample2023,
  author    = {Researcher, A. and Colleague, B.},
  title     = {A Conference Paper Title},
  booktitle = {Proceedings of the XYZ Conference},
  year      = {2023},
  pages     = {100--110},
  doi       = {10.xxxx/confexample},
}

% --- ArXiv 预印本示例 ---
@article{arxiv2024,
  author      = {Author, Name},
  title       = {Title of the Preprint},
  journal     = {arXiv preprint arXiv:2401.00001},
  year        = {2024},
}
